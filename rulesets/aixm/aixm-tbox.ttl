# AIXM TBox — supplementary domain axioms for the lakehouse reasoner
#
# Pairs with: aixm-ruleset-domain_range.rules (so rules 1, 3, 7, 8 fire).
# Base URI:   matches what aixm-engine emits (AixmConstants.BASE_URI), so the
#             axioms here apply directly to the asserted instance triples
#             produced by AixmRdfWriter.
#
# Out of scope on purpose: data cardinality, datatype constraints, code lists,
# and anything else the OWL 2 RL fragment does not handle.

@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix aixm: <http://example.org/bigkgolap/atm/aixm#> .

#-------------------------------------------------------------------------
# 1. Navaid equipment hierarchy  (exercises Rule 1: subClassOf)
#
# AIXM models the concrete radio-navigation equipment types as
# specializations of the abstract NavaidEquipment class. A query that asks
# "which features are navaid equipment?" must collect VORs, NDBs, DMEs, …
# via subClassOf reasoning.
#-------------------------------------------------------------------------

aixm:NavaidEquipment a rdfs:Class .

aixm:VOR          a rdfs:Class ; rdfs:subClassOf aixm:NavaidEquipment .
aixm:NDB          a rdfs:Class ; rdfs:subClassOf aixm:NavaidEquipment .
aixm:DME          a rdfs:Class ; rdfs:subClassOf aixm:NavaidEquipment .
aixm:TACAN        a rdfs:Class ; rdfs:subClassOf aixm:NavaidEquipment .
aixm:Glidepath    a rdfs:Class ; rdfs:subClassOf aixm:NavaidEquipment .
aixm:Localizer    a rdfs:Class ; rdfs:subClassOf aixm:NavaidEquipment .
aixm:MarkerBeacon a rdfs:Class ; rdfs:subClassOf aixm:NavaidEquipment .

#-------------------------------------------------------------------------
# 2. Feature-to-feature property typing  (exercises Rules 7 & 8: domain / range)
#
# These axioms let the reasoner infer the type of a feature from the role
# it plays in a property assertion — e.g. anything that appears as the
# subject of an associatedAirportHeliport triple is a Runway, and the
# object is an AirportHeliport.
#-------------------------------------------------------------------------

aixm:associatedAirportHeliport
    a rdf:Property ;
    rdfs:domain aixm:Runway ;
    rdfs:range  aixm:AirportHeliport .

aixm:usedRunway
    a rdf:Property ;
    rdfs:domain aixm:RunwayDirection ;
    rdfs:range  aixm:Runway .

aixm:locationIndicatorICAO
    a rdf:Property ;
    rdfs:domain aixm:AirportHeliport ;
    rdfs:range  xsd:string .

#-------------------------------------------------------------------------
# 3. Property chain: a RunwayDirection's airport  (exercises Rule 3)
#
#     RunwayDirection --usedRunway--> Runway --associatedAirportHeliport--> AirportHeliport
#
# entails
#
#     RunwayDirection --atAirport--> AirportHeliport
#
# Useful for queries like "which RunwayDirections belong to airport LOWS?"
# without having to traverse two hops manually.
#-------------------------------------------------------------------------

aixm:atAirport
    a rdf:Property ;
    rdfs:range aixm:AirportHeliport ;
    owl:propertyChainAxiom ( aixm:usedRunway aixm:associatedAirportHeliport ) .
